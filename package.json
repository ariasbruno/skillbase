{
  "name": "@ariasbruno/skillbase",
  "version": "1.1.0",
  "description": "CLI to manage local and remote AI skills avoiding context bloat",
  "type": "module",
  "bin": {
    "skillbase": "bin/skillbase.js"
  },
  "scripts": {
    "start": "node bin/skillbase.js -h",
    "test": "node --test",
    "lint": "for f in bin/skillbase.js src/*.js src/commands/*.js src/locales/*.js; do node --check \"$f\" || exit 1; done",
    "build": "esbuild src/cli.js --bundle --platform=node --target=node18 --format=esm --splitting --outdir=dist --minify"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ariasbruno/skillbase.git"
  },
  "bugs": {
    "url": "https://github.com/ariasbruno/skillbase/issues"
  },
  "homepage": "https://github.com/ariasbruno/skillbase#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "skills",
    "cli",
    "agents",
    "ai",
    "context",
    "bloat",
    "developer-tools"
  ],
  "devDependencies": {
    "esbuild": "0.28.0",
    "node-pty": "1.1.0"
  }
}
